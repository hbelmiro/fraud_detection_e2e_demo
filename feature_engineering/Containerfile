FROM spark:python3-java17

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    APP_HOME=/app \
    PATH="$APP_HOME/feature_repo/venv/bin:$PATH"

RUN curl -L https://repo1.maven.org/maven2/org/apache/hadoop/hadoop-aws/3.3.4/hadoop-aws-3.3.4.jar -o /opt/spark/jars/hadoop-aws-3.3.4.jar
RUN curl -L https://repo1.maven.org/maven2/com/amazonaws/aws-java-sdk-bundle/1.12.262/aws-java-sdk-bundle-1.12.262.jar -o /opt/spark/jars/aws-java-sdk-bundle-1.12.262.jar

USER root

WORKDIR $APP_HOME/feature_repo

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3-venv \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && chown -R spark:spark $APP_HOME/feature_repo

COPY requirements.txt .

RUN pip install -r requirements.txt \
    && rm requirements.txt

USER spark

COPY feature_repo/repo_definition.py $APP_HOME/feature_repo/
COPY feature_repo/feature_store.yaml $APP_HOME/feature_repo/

COPY feast_apply.py $APP_HOME

ENV MINIO_ENDPOINT="http://minio-service.kubeflow.svc.cluster.local:9000" \
    MINIO_ACCESS_KEY="minio" \
    MINIO_SECRET_KEY="minio123" \
    MINIO_BUCKET="mlpipeline" \
    FEATURE_REPO_REMOTE_DIR="artifacts/feature_repo" \
    FEATURE_REPO_LOCAL_DIR="$APP_HOME/feature_repo"
